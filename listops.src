//listops.src
Listops = {}

Listops.removeEntries = function(list, entry)
    if list.len == 0 then return
    for i in range(list.len - 1, 0)
        if list[i] == entry then list.remove(i)
    end for
end function

Listops.transform = function(list, transformer)
    newList = []
    for item in list
        newList.push(transformer(item))
    end for
    return newList
end function