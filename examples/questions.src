// 1. Простой ввод
ip = ui.ask("Введите IP для сканирования", "127.0.0.1")
ui.info("Выбран адрес: " + ip)

// 2. Меню выбора
modes = ["Быстрое сканирование", "Глубокий анализ", "Взлом портов"]
action = ui.select("Доступные действия", modes)

// 3. Подтверждение
if ui.confirm("Вы уверены, что хотите начать " + action + "?") then
    ui.success("Запуск процесса: " + action + "...")
else
    ui.warn("Действие отменено пользователем.")
end if